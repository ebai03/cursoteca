# Nextcloud AIO configuration template

# ====== SYSTEM ACCESS ======
# Your public domain name (e.g., nextcloud.example.com)
NEXTCLOUD_DOMAIN=domain.example.com

# If you don't have a domain yet, leave empty or use your local IP for testing
# NEXTCLOUD_DOMAIN=192.168.1.100

# ====== STORAGE ======
# Host path for Nextcloud data storage (ensure this directory exists)
# WARNING: Do not change this value after the initial installation
NEXTCLOUD_DATADIR=/var/lib/docker/volumes/nextcloud_aio_nextcloud_data/_data

# File upload limits (e.g., 10G, 512M)
NEXTCLOUD_UPLOAD_LIMIT=10G

# Maximum execution time in seconds (standard: 3600)
NEXTCLOUD_MAX_TIME=3600

# PHP memory limit (standard: 512M)
NEXTCLOUD_MEMORY_LIMIT=512M

# ====== SECURITY ======
# Set to 'true' only if you are behind a proxy and domain validation fails
SKIP_DOMAIN_VALIDATION=false

# ====== APPS TO INSTALL ======
# List of apps to install automatically on first startup
NEXTCLOUD_STARTUP_APPS=deck twofactor_totp tasks calendar contacts notes

# ====== BACKUPS ======
# Borg backup retention policy (e.g., keep last 7 days, 4 weeks, 6 months)
BORG_RETENTION_POLICY=--keep-within=7d --keep-weekly=4 --keep-monthly=6

# ====== COLLABORATION (Talk) ======
# Port used by Nextcloud Talk for signaling and STUN/TURN
TALK_PORT=3478

# ====== REVERSE PROXY CONFIGURATION ======
# Uncomment if you are running this behind Nginx, Caddy, or Apache
# APACHE_PORT=11000
# APACHE_IP_BINDING=127.0.0.1

# To enable IPv6 support
# DOCKER_ENABLE_IPV6=true

# Additional packages (e.g., imagemagick for image processing)
# NEXTCLOUD_ADDITIONAL_APKS=imagemagick

# Additional PHP extensions
# NEXTCLOUD_ADDITIONAL_PHP_EXTENSIONS=imagick