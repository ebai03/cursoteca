# http:// prefix — Cloudflare handles TLS, origin serves plain HTTP
http://aecci-ucr.com {
    # Enable compression for faster loading
    encode gzip

    # 1. Serve static files from the frontend folder
    root * /var/www/frontend

    # Add security headers
    header {
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Enable XSS protection
        X-Content-Type-Options "nosniff"

    }

    # Add cache control only for static assets (CSS, JS, images, fonts, etc.)
    @static_assets {
        path *.css *.js *.png *.jpg *.jpeg *.gif *.svg *.ico *.webp *.woff *.woff2 *.ttf *.eot
    }
    header @static_assets {
        Cache-Control "public, max-age=3600"
    }

    @stats {
        path /stats.json
    }
    header @stats {
        Cache-Control "public, max-age=120"
        Content-Type "application/json"
    }
    
    file_server

    # 2. Intercept requests to /cursos and show the file browser
    handle_path /cursos/* {
        root * /var/www/cursos

        # Prevent browsers from caching directory listings
        header Cache-Control "no-store"

        # Enable the directory browser and hide hidden/git files
        file_server {
            browse /var/www/frontend/browse.html
            hide .* .gitkeep .gitignore .gitattributes .gitmodules
        }
    }

    # 3. Optional: Redirect old paths
    redir /explore /cursos/ 301

    # 4. Error handling
    handle_errors {
        @404 {
            expression {http.error.status_code} == 404
        }
        rewrite @404 /404.html
        file_server
    }

    # Logging with rotation
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 3
            roll_uncompressed
        }
        format json
    }
}

# Admin subdomain for managing content through FileBrowser
http://admin.aecci-ucr.com {
    reverse_proxy filebrowser:80
}
